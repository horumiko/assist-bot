  "version": "1.0.0",
  "description": "Personal Telegram assistant with Todoist, Google Calendar, Bitrix24 and LLM integration",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
